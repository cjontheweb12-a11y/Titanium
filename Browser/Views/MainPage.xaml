<!-- Browser/Views/MainPage.xaml -->
<Page
    x:Class="Browser.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Browser.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Browser.ViewModels"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
    Motivo: Se define el tipo de ViewModel asociado a esta View para el diseño de tiempo de diseño.
    Esto ayuda a Visual Studio a proporcionar IntelliSense y vista previa de datos durante el desarrollo.
    -->
    <Page.DataContext>
        <viewmodels:MainViewModel/>
    </Page.DataContext>

    <!--
    Motivo: NavigationView es el control principal para la navegación de la aplicación UWP.
    Ofrece un panel lateral (hamburger menu) para la navegación principal y una barra superior
    para el título y acciones clave. Permite una interfaz moderna y responsiva.
    -->
    <controls:NavigationView
        x:Name="NavigationViewControl"
        IsSettingsVisible="True"
        IsBackButtonVisible="Collapsed"
        PaneDisplayMode="Left"
        ExpandedModeThresholdWidth="640"
        SelectionChangedCommand="{Binding NavigationViewSelectionChangedCommand}">

        <!-- Contenido principal de la NavigationView -->
        <controls:NavigationView.Content>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Barra de navegación -->
                    <RowDefinition Height="Auto"/> <!-- TabView -->
                    <RowDefinition Height="*"/>    <!-- Contenido del navegador/páginas internas -->
                </Grid.RowDefinitions>

                <!--
                Motivo: Barra de navegación superior con controles de navegador.
                Utiliza un Grid para organizar los elementos de forma estructurada.
                -->
                <Grid Grid.Row="0" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,0,1"
                      Background="{StaticResource SecondaryBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Botón Atrás -->
                        <ColumnDefinition Width="Auto"/> <!-- Botón Adelante -->
                        <ColumnDefinition Width="Auto"/> <!-- Botón Refrescar/Detener -->
                        <ColumnDefinition Width="*"/>    <!-- Barra de dirección/búsqueda -->
                        <ColumnDefinition Width="Auto"/> <!-- Botón Marcadores -->
                        <ColumnDefinition Width="Auto"/> <!-- Botón Home -->
                    </Grid.ColumnDefinitions>

                    <!--
                    Motivo: Botones de navegación (Atrás, Adelante, Refrescar/Detener, Marcadores, Home).
                    Están enlazados a los comandos correspondientes en MainViewModel.
                    Se utilizan FontIcon para los iconos del sistema (Segoe MDL2 Assets).
                    -->
                    <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                            IsEnabled="{Binding IsBackEnabled}"
                            Style="{StaticResource BaseButtonStyle}"
                            Width="40" Height="40" Background="Transparent"
                            Margin="4,0,0,0" Padding="0">
                        <FontIcon Glyph="&#xE72B;" Foreground="{StaticResource PrimaryForegroundBrush}" FontSize="16"/>
                    </Button>
                    <Button Grid.Column="1" Command="{Binding GoForwardCommand}"
                            IsEnabled="{Binding IsForwardEnabled}"
                            Style="{StaticResource BaseButtonStyle}"
                            Width="40" Height="40" Background="Transparent"
                            Margin="0" Padding="0">
                        <FontIcon Glyph="&#xE72A;" Foreground="{StaticResource PrimaryForegroundBrush}" FontSize="16"/>
                    </Button>

                    <!-- Botón Refrescar/Detener -->
                    <!--
                    Motivo: Un ToggleButton se utiliza para alternar entre los iconos de refrescar y detener.
                    La propiedad IsChecked está enlazada a IsLoading de la ViewModel.
                    El Command está enlazado condicionalmente a RefreshCommand o StopCommand.
                    -->
                    <ToggleButton Grid.Column="2" IsChecked="{Binding IsLoading, Mode=OneWay}"
                                  Command="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsChecked, Converter={StaticResource BooleanToCommandConverter}, ConverterParameter={Binding DataContext.StopCommand}, FallbackValue={Binding DataContext.RefreshCommand}}"
                                  Style="{StaticResource NavigationToggleButton}"
                                  Width="40" Height="40" Margin="0" Padding="0">
                        <StackPanel>
                            <FontIcon Glyph="&#xE72C;" FontSize="16" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}"/>
                            <FontIcon Glyph="&#xE71A;" FontSize="16" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </ToggleButton>


                    <!-- Barra de Dirección y Búsqueda -->
                    <Grid Grid.Column="3" Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Icono de seguridad (candado) -->
                            <ColumnDefinition Width="*"/>    <!-- AutoSuggestBox -->
                        </Grid.ColumnDefinitions>
                        <!--
                        Motivo: Icono de candado para HTTPS.
                        Su visibilidad está enlazada a la propiedad IsHttps de la ViewModel.
                        -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0"
                                    Visibility="{Binding IsHttps, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="Green"/>
                        </StackPanel>
                        <!--
                        Motivo: AutoSuggestBox para la barra de dirección/búsqueda.
                        Permite al usuario introducir URLs o términos de búsqueda.
                        El comando NavigateCommand se ejecuta al presionar Enter.
                        -->
                        <AutoSuggestBox Grid.Column="1"
                                        QueryIcon="Globe"
                                        PlaceholderText="Buscar o introducir dirección web"
                                        Text="{Binding SelectedTab.AddressBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        QuerySubmitted="AddressBar_QuerySubmitted"
                                        Loaded="AddressBar_Loaded"
                                        Style="{StaticResource DefaultAutoSuggestBoxStyle}"/>
                    </Grid>

                    <Button Grid.Column="4" Command="{Binding AddBookmarkCommand}"
                            IsEnabled="{Binding SelectedTab.CanGoBack}"
                            Style="{StaticResource BaseButtonStyle}"
                            Width="40" Height="40" Background="Transparent"
                            Margin="0" Padding="0">
                        <FontIcon Glyph="&#xE718;" Foreground="{StaticResource PrimaryForegroundBrush}" FontSize="16"/>
                    </Button>
                    <Button Grid.Column="5" Command="{Binding GoHomeCommand}"
                            Style="{StaticResource BaseButtonStyle}"
                            Width="40" Height="40" Background="Transparent"
                            Margin="0,0,4,0" Padding="0">
                        <FontIcon Glyph="&#xE80F;" Foreground="{StaticResource PrimaryForegroundBrush}" FontSize="16"/>
                    </Button>
                </Grid>

                <!--
                Motivo: TabView para la navegación por pestañas.
                Enlazado a la colección BrowserTabs de la ViewModel.
                Permite añadir y cerrar pestañas.
                -->
                <controls:TabView Grid.Row="1"
                                  x:Name="BrowserTabView"
                                  ItemsSource="{Binding BrowserTabs}"
                                  SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                                  AddTabButtonCommand="{Binding AddNewTabCommand}"
                                  CanReorderTabs="True"
                                  CanCloseTabs="True"
                                  AllowDrop="True"
                                  TabCloseRequestedCommand="{Binding CloseTabCommand}"
                                  TabWidthMode="SizeToContent"
                                  HorizontalAlignment="Stretch">
                    <controls:TabView.TabStripHeader>
                        <!-- Motivo: Espaciador para alinear el TabView con la barra de navegación del NavigationView. -->
                        <Grid Width="{Binding ElementName=NavigationViewControl, Path=CompactPaneLength}" />
                    </controls:TabView.TabStripHeader>
                    <controls:TabView.Resources>
                        <Thickness x:Key="TabViewItemHeaderMargin">0,0,0,-1</Thickness>
                        <Style TargetType="controls:TabViewItem" BasedOn="{StaticResource DefaultTabViewItemStyle}">
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
                            <Setter Property="CornerRadius" Value="4,4,0,0"/>
                            <Setter Property="Margin" Value="2,0"/>
                            <Setter Property="controls:TabViewItem.TabViewItemIndicator" Value="{StaticResource TabViewTabSelectedIndicator}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="controls:TabViewItem">
                                        <Grid x:Name="RootGrid"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              CornerRadius="{TemplateBinding CornerRadius}"
                                              Opacity="{TemplateBinding Opacity}">
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CloseButton" Storyboard.TargetProperty="Opacity">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="0"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="PointerOver">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TertiaryBackgroundBrush}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CloseButton" Storyboard.TargetProperty="Opacity">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="1"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="Pressed">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SystemControlBackgroundBaseMediumLowBrush}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="Selected">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource SecondaryBackgroundBrush}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CloseButton" Storyboard.TargetProperty="Opacity">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="1"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabViewItemIndicator" Storyboard.TargetProperty="Visibility">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="Disabled">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Content" Storyboard.TargetProperty="Foreground">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SystemControlDisabledBaseMediumLowBrush}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter x:Name="Content"
                                                              Content="{TemplateBinding Header}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              Margin="{TemplateBinding Padding}"/>
                                            <Button x:Name="CloseButton" Grid.Column="1" Style="{StaticResource AppBarButtonStyle}"
                                                    Background="Transparent" Width="32" Height="32"
                                                    VerticalAlignment="Center" Margin="0" Opacity="0">
                                                <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                            </Button>
                                            <Rectangle x:Name="TabViewItemIndicator"
                                                       Visibility="Collapsed"
                                                       Style="{StaticResource TabViewTabSelectedIndicator}"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:TabView.Resources>

                    <!--
                    Motivo: Definir cómo se ve cada elemento del TabView.
                    El Header se enlaza a la propiedad Title de la BrowserTabViewModel.
                    -->
                    <controls:TabView.ItemHeaderTemplate>
                        <DataTemplate x:DataType="viewmodels:BrowserTabViewModel">
                            <StackPanel Orientation="Horizontal" ToolTipService.ToolTip="{Binding CurrentUri}">
                                <FontIcon Glyph="&#xE774;" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </controls:TabView.ItemHeaderTemplate>
                </controls:TabView>

                <!--
                Motivo: Frame para contener el BrowserTabUserControl de la pestaña seleccionada
                o las páginas internas (Configuración, Historial, Marcadores).
                Este Frame es el que utiliza el NavigationService.
                -->
                <Frame x:Name="ContentFrame" Grid.Row="2" />
            </Grid>
        </controls:NavigationView.Content>

        <!-- Elementos de navegación del panel lateral -->
        <controls:NavigationView.MenuItems>
            <!--
            Motivo: Estos elementos de NavigationViewItem representan las diferentes secciones
            de la aplicación. Cada uno tiene un Tag que se utiliza en el comando
            NavigationViewSelectionChangedCommand para determinar a qué página navegar.
            -->
            <controls:NavigationViewItem Content="Inicio" Icon="Home" Tag="Home"/>
            <controls:NavigationViewItemSeparator/>
            <controls:NavigationViewItem Content="Marcadores" Icon="Favorite" Tag="Bookmarks"/>
            <controls:NavigationViewItem Content="Historial" Icon="History" Tag="History"/>
            <controls:NavigationViewItem Content="Descargas" Icon="Download" Tag="Downloads"/>
        </controls:NavigationView.MenuItems>
    </controls:NavigationView>
</Page>
