<!-- Browser/Views/DownloadManagerPage.xaml -->
<Page
    x:Class="Browser.Views.DownloadManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Browser.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Browser.ViewModels"
    mc:Ignorable="d"
    Background="{StaticResource PrimaryBackgroundBrush}">

    <!--
    Motivo: Se define el tipo de ViewModel asociado a esta View para el diseño de tiempo de diseño.
    Esto ayuda a Visual Studio a proporcionar IntelliSense y vista previa de datos durante el desarrollo.
    -->
    <Page.DataContext>
        <viewmodels:DownloadManagerViewModel/>
    </Page.DataContext>

    <!--
    Motivo: Usar un Grid como contenedor principal para organizar los elementos en filas y columnas.
    -->
    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Título de la página -->
            <RowDefinition Height="*"/>    <!-- Lista de descargas -->
            <RowDefinition Height="Auto"/> <!-- Controles de descarga -->
        </Grid.RowDefinitions>

        <!-- Título de la página -->
        <TextBlock Grid.Row="0" Text="Mis Descargas"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,20"
                   Foreground="{StaticResource PrimaryForegroundBrush}"/>

        <!-- Lista de Descargas -->
        <!--
        Motivo: ListView para mostrar la colección de elementos de descarga.
        Permite la selección de un elemento y el enlace a comandos.
        -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding ActiveDownloads}"
                  SelectedItem="{Binding SelectedDownload, Mode=TwoWay}"
                  SelectionMode="Single"
                  Margin="0,0,0,20">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:DownloadItem">
                    <Grid Padding="5" ColumnSpacing="10" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" Text="{Binding FileName}"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{StaticResource PrimaryForegroundBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding SourceUrl}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{StaticResource SecondaryForegroundBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="0" Grid.Row="2" Text="{Binding Status}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{StaticResource PrimaryForegroundBrush}"/>

                        <ProgressBar Grid.Column="1" Grid.RowSpan="3" VerticalAlignment="Center"
                                     Value="{Binding Progress}" Minimum="0" Maximum="100" Width="100"
                                     Margin="10,0"
                                     Visibility="{Binding Status, Converter={StaticResource DownloadStatusToProgressVisibilityConverter}}"/>

                        <TextBlock Grid.Column="2" Grid.RowSpan="3" VerticalAlignment="Center"
                                   Text="{Binding Progress, StringFormat='{}{0:F0}%'}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Visibility="{Binding Status, Converter={StaticResource DownloadStatusToProgressVisibilityConverter}}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <!--
                Motivo: Aplicar un estilo de contenedor para cada elemento de la lista,
                añadiendo margen y bordes redondeados para una mejor apariencia.
                -->
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
                    <Setter Property="CornerRadius" Value="4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Controles de Descarga (Pausar, Reanudar, Cancelar, Abrir Archivo, Abrir Carpeta) -->
        <!--
        Motivo: La visibilidad de esta sección se enlaza condicionalmente a SelectedDownload.
        Solo se muestra cuando hay una descarga seleccionada.
        -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right"
                    Visibility="{Binding SelectedDownload, Converter={StaticResource ObjectToVisibilityConverter}}">
            <Button Content="Pausar"
                    Command="{Binding PauseDownloadCommand}"
                    Style="{StaticResource BaseButtonStyle}"
                    Background="{StaticResource SofttekBlueBrush}"
                    Foreground="{StaticResource SecondaryBackgroundBrush}"/>
            <Button Content="Reanudar"
                    Command="{Binding ResumeDownloadCommand}"
                    Style="{StaticResource BaseButtonStyle}"
                    Background="{StaticResource SofttekBlueBrush}"
                    Foreground="{StaticResource SecondaryBackgroundBrush}"/>
            <Button Content="Cancelar"
                    Command="{Binding CancelDownloadCommand}"
                    Style="{StaticResource BaseButtonStyle}"
                    Background="{StaticResource ErrorForegroundBrush}"
                    Foreground="{StaticResource SecondaryBackgroundBrush}"/>
            <Button Content="Abrir Archivo"
                    Command="{Binding OpenDownloadCommand}"
                    Style="{StaticResource BaseButtonStyle}"
                    Background="{StaticResource SofttekBlueBrush}"
                    Foreground="{StaticResource SecondaryBackgroundBrush}"/>
            <Button Content="Abrir Carpeta"
                    Command="{Binding OpenDownloadFolderCommand}"
                    Style="{StaticResource BaseButtonStyle}"
                    Background="{StaticResource SofttekBlueBrush}"
                    Foreground="{StaticResource SecondaryBackgroundBrush}"/>
        </StackPanel>
    </Grid>
</Page>
