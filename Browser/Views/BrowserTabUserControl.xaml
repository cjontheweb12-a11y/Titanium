<!-- Browser/Views/BrowserTabUserControl.xaml -->
<UserControl
    x:Class="Browser.Views.BrowserTabUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Browser.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Browser.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=viewmodels:BrowserTabViewModel, Is='True'}">

    <!--
    Motivo: Este UserControl representa el contenido de una sola pestaña del navegador.
    Contiene el control WebView y elementos visuales asociados a la carga de la página.
    Su DataContext se establece programáticamente en MainPage.xaml.cs.
    -->
    <Grid Background="{StaticResource SecondaryBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Barra de progreso -->
            <RowDefinition Height="*"/>    <!-- WebView -->
        </Grid.RowDefinitions>

        <!--
        Motivo: Barra de progreso lineal para indicar la carga de la página.
        Su visibilidad está enlazada a la propiedad IsLoading.
        Su valor está enlazado a la propiedad LoadingProgress.
        -->
        <ProgressBar Grid.Row="0"
                     IsIndeterminate="False"
                     Value="{Binding LoadingProgress, Mode=OneWay}"
                     Minimum="0" Maximum="100"
                     Height="3"
                     Background="Transparent"
                     Foreground="{StaticResource SofttekBlueBrush}"
                     VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!--
        Motivo: Control principal para mostrar contenido web.
        Su nombre (WebViewControl) se usa para acceder a él desde el code-behind de este UserControl
        y asociarlo a la ViewModel.
        -->
        <WebView Grid.Row="1" x:Name="WebViewControl"/>
    </Grid>
</UserControl>
